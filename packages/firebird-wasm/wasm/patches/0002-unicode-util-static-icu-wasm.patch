+#ifdef __EMSCRIPTEN__
+// Emscripten/WASM: ICU is linked statically via -sUSE_ICU=1.
+// Create an ICU instance with function pointers set directly to the real
+// ICU functions instead of loading them dynamically via dlsym.
+//
+// A single static ICU instance is returned for every version request;
+// the Emscripten build ships exactly one ICU version.
+UnicodeUtil::ICU* UnicodeUtil::loadICU(const Firebird::string& /*icuVersion*/,
+	const Firebird::string& /*configInfo*/)
+{
+	// Singleton: create once, return the same instance on every call.
+	static ICU* wasmIcu = nullptr;
+	if (wasmIcu)
+		return wasmIcu;
+
+	wasmIcu = FB_NEW_POOL(*getDefaultMemoryPool()) ICU(
+		U_ICU_VERSION_MAJOR_NUM, U_ICU_VERSION_MINOR_NUM);
+
+	// The Emscripten build does not use dynamic module loading.
+	// inModule and ucModule stay NULL – the destructor handles NULL safely.
+
+	// ── common library (libicuuc) functions ─────────────────────────
+	wasmIcu->uVersionToString   = u_versionToString;
+	wasmIcu->ulocCountAvailable = uloc_countAvailable;
+	wasmIcu->ulocGetAvailable   = uloc_getAvailable;
+	wasmIcu->usetClose          = uset_close;
+	wasmIcu->usetGetItem        = uset_getItem;
+	wasmIcu->usetGetItemCount   = uset_getItemCount;
+	wasmIcu->usetOpen           = uset_open;
+
+	// ── i18n library (libicui18n) functions ─────────────────────────
+	wasmIcu->ucolClose                       = ucol_close;
+	wasmIcu->ucolGetContractionsAndExpansions = ucol_getContractionsAndExpansions;
+	wasmIcu->ucolGetRules                    = ucol_getRules;
+	wasmIcu->ucolGetSortKey                  = ucol_getSortKey;
+	wasmIcu->ucolOpen                        = ucol_open;
+	wasmIcu->ucolOpenRules                   = ucol_openRules;
+	wasmIcu->ucolSetAttribute                = ucol_setAttribute;
+	wasmIcu->ucolStrColl                     = ucol_strcoll;
+	wasmIcu->ucolGetVersion                  = ucol_getVersion;
+	wasmIcu->utransOpenU                     = utrans_openU;
+	wasmIcu->utransClose                     = utrans_close;
+	wasmIcu->utransTransUChars               = utrans_transUChars;
+
+	// ── Obtain the default collation version ────────────────────────
+	UErrorCode status = U_ZERO_ERROR;
+	UCollator* collator = wasmIcu->ucolOpen("", &status);
+	if (collator)
+	{
+		wasmIcu->ucolGetVersion(collator, wasmIcu->collVersion);
+		wasmIcu->ucolClose(collator);
+	}
+
+	return wasmIcu;
+}
+#else
 UnicodeUtil::ICU* UnicodeUtil::loadICU(const string& icuVersion, const string& configInfo)
 {
