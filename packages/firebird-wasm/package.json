{
  "name": "firebird-wasm",
  "version": "0.1.0",
  "description": "Firebird embedded in WASM, similar to PGlite for PostgreSQL",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "jest --forceExit",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "firebird",
    "wasm",
    "embedded",
    "database",
    "sql"
  ],
  "author": "mariuz",
  "license": "Apache-2.0",
  "dependencies": {
    "node-firebird-driver-native": "^3.5.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.10",
    "@typescript-eslint/eslint-plugin": "^7.17.0",
    "@typescript-eslint/parser": "^7.17.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.2",
    "typescript": "^5.5.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/src/**/*.test.ts", "**/src/**/__tests__/**/*.test.ts"],
    "testTimeout": 30000
  }
}
